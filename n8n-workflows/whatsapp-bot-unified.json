    {
      "parameters": {
        "jsCode": "const config = typeof $json.userConfig === 'string' ? JSON.parse($json.userConfig) : $json.userConfig;\n\nconst toneMap = {\n  profissional: 'profissional e formal. Transmita confianca e seriedade',\n  amigavel: 'amigavel e acolhedor. Use um tom proximo e simpatico',\n  casual: 'casual e descontraido. Fale de forma leve e natural',\n  persuasivo: 'persuasivo e envolvente. Use gatilhos de interesse e urgencia'\n};\nconst styleMap = {\n  direto: 'Seja direto e objetivo. Respostas curtas e praticas',\n  detalhado: 'Seja detalhado e completo. Explique com clareza cada ponto',\n  consultivo: 'Seja consultivo. Faca perguntas para entender melhor antes de responder',\n  agressivo: 'Seja focado em conversao. Sempre direcione para a venda ou acao',\n  simples: 'Use linguagem simples e facil. Evite termos tecnicos'\n};\nconst goalMap = {\n  vender: 'vender produtos e servicos. Guie o cliente naturalmente ate a compra',\n  suporte: 'fornecer suporte ao cliente. Resolva duvidas e problemas com eficiencia',\n  leads: 'captar leads qualificados. Colete informacoes de contato de forma natural',\n  agendamento: 'agendar horarios. Ajude o cliente a encontrar o melhor horario disponivel'\n};\nconst behaviorMap = {\n  objetivo: 'Seja objetivo e va direto ao ponto.',\n  conversacional: 'Mantenha um tom conversacional, como um bate-papo natural.',\n  vendas: 'Sempre direcione para oportunidades de venda.',\n  suporte: 'Priorize resolver o problema do cliente. Seja paciente e empatico.'\n};\n\nlet faqBlock = '';\nif (config.faq && config.faq.length > 0) {\n  const faqItems = config.faq.slice(0, 5).map(f => 'Pergunta: ' + f.q + '\\nResposta: ' + f.a).join('\\n\\n');\n  faqBlock = '\\n\\n---\\nPERGUNTAS FREQUENTES:\\n\\n' + faqItems;\n}\n\nconst systemPrompt = 'Voce e ' + (config.aiName || 'Assistente') + ', um assistente virtual.\\n\\nNEGOCIO: ' + (config.businessContext || 'Atendimento geral.') + '\\n\\nTOM: ' + (toneMap[config.tone] || toneMap.profissional) + '.\\n\\nESTILO: ' + (styleMap[config.style] || styleMap.direto) + '.\\n\\nCOMPORTAMENTO: ' + (behaviorMap[config.behavior] || behaviorMap.objetivo) + '\\n\\nOBJETIVO: ' + (goalMap[config.goal] || goalMap.suporte) + '.\\n\\nRegras:\\n- Responda em portugues brasileiro\\n- Nunca invente informacoes\\n- Respostas curtas para WhatsApp\\n- Negrito: *palavra*\\n- Se pedir humano: Entendido! Vou chamar um atendente agora.' + faqBlock;\n\nreturn [{ json: { ...$json, systemPrompt } }];"
      },

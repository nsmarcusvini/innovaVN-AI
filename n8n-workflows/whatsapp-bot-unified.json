    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst required = ['aiName', 'whatsappNumber', 'tone', 'style', 'goal'];\nconst missing = required.filter(f => !body[f] || String(body[f]).trim() === '');\n\nif (missing.length > 0) {\n  return [{ json: { valid: false, success: false, error: 'Campos obrigatorios faltando: ' + missing.join(', ') } }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    aiName: String(body.aiName).trim(),\n    whatsappNumber: String(body.whatsappNumber).replace(/\\D/g, ''),\n    tone: String(body.tone).trim(),\n    style: String(body.style).trim(),\n    behavior: String(body.behavior || 'objetivo').trim(),\n    businessContext: String(body.businessContext || '').trim(),\n    goal: String(body.goal).trim(),\n    faq: Array.isArray(body.faq) ? body.faq : [],\n    plan: String(body.plan || 'Basico').trim()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-400, 300],
      "id": "a1b2c3d4-0002-4000-a000-000000000002",
      "name": "Valida Dados"

    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst phone = data.whatsappNumber;\nconst instanceName = 'ia_' + phone;\nconst userId = 'usr_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 6);\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.users) staticData.users = {};\n\nconst isUpdate = !!staticData.users[phone];\nconst existingUserId = isUpdate ? staticData.users[phone].userId : userId;\n\nstaticData.users[phone] = {\n  userId: existingUserId,\n  aiName: data.aiName,\n  tone: data.tone,\n  style: data.style,\n  behavior: data.behavior,\n  businessContext: data.businessContext,\n  goal: data.goal,\n  faq: data.faq,\n  plan: data.plan,\n  whatsappNumber: phone,\n  createdAt: isUpdate ? staticData.users[phone].createdAt : new Date().toISOString(),\n  updatedAt: new Date().toISOString(),\n  active: true\n};\n\nreturn [{\n  json: {\n    success: true,\n    userId: existingUserId,\n    phone: phone,\n    instanceName: instanceName,\n    isUpdate: isUpdate,\n    message: isUpdate ? 'Config atualizada' : 'IA configurada'\n  }\n}];"
      },

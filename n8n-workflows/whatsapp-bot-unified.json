    {
      "parameters": {
        "jsCode": "const telefone = $json.telefone\n  .replace('@s.whatsapp.net', '')\n  .replace(/\\D/g, '');\n\nconst staticData = $getWorkflowStaticData('global');\nconst users = staticData.users || {};\n\nconst phoneVariants = [telefone, telefone.replace(/^55/, ''), '55' + telefone];\n\nlet config = null;\nfor (const variant of phoneVariants) {\n  if (users[variant]) { config = users[variant]; break; }\n}\n\nif (!config) {\n  config = {\n    aiName: 'Assistente',\n    tone: 'profissional',\n    style: 'direto',\n    behavior: 'objetivo',\n    businessContext: 'Assistente geral de atendimento ao cliente',\n    goal: 'suporte',\n    faq: [],\n    plan: 'Basico',\n    isDefault: true\n  };\n}\n\nreturn [{ json: { ...$json, userConfig: config } }];"
      },
